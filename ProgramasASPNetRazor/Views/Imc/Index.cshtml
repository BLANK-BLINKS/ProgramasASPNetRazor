@model IEnumerable<ProgramasASPNetRazor.Models.ImcModel>

@{
    ViewData["Title"] = "Lista de IMC";
}

<h1>Lista de IMC</h1>

<p>
    <a asp-action="Create">Calcular un nuevo IMC</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Peso)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Altura)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Imc)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Clasificacion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Recomendacion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Imagen)
            </th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Nombre)
            </td>
            <td>
                @Html.DisplayFor(model => item.Peso)
            </td>
            <td>
                @Html.DisplayFor(model => item.Altura)
            </td>
            <td>
                @Html.DisplayFor(model => item.Imc)
            </td>
            <td>
                @Html.DisplayFor(model => item.Clasificacion)
            </td>
            <td>
                @Html.DisplayFor(model => item.Recomendacion)
            </td>
                <td>
                    <img src="@item.Imagen" alt="@item.Clasificacion" width="100" /> 
                </td>
        </tr>
}
    </tbody>
</table>
